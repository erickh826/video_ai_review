# ===== App =====
APP_ENV=local
APP_URL=http://localhost:3000

# ===== Azure OpenAI (Azure AI) =====
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-xx-xx
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=

# ===== Storage: choose one =====
STORAGE_PROVIDER=s3  # or blob

# --- AWS S3 ---
AWS_REGION=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PREFIX=video-review/

# --- Azure Blob ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=video-review

# ===== Database =====
DATABASE_URL=

# ===== Background Jobs (optional but recommended) =====
REDIS_URL=

# ===== Observability (optional) =====
SENTRY_DSN=