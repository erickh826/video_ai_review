# ===== App =====
APP_ENV=local        # local | staging | production
APP_URL=http://localhost:3000

# ===== Azure OpenAI (Azure AI) =====
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_API_VERSION=2024-xx-xx
AZURE_OPENAI_CHAT_DEPLOYMENT=chat-model-name
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=embeddings-model-name

# ===== Storage: choose one =====
STORAGE_PROVIDER=s3  # or blob

# --- AWS S3 ---
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_PREFIX=video-review/

# --- Azure Blob ---
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER=video-review

# ===== Database =====
DATABASE_URL=postgres://user:password@host:5432/dbname

# ===== Background Jobs (optional but recommended) =====
REDIS_URL=redis://localhost:6379


# ===== Observability (optional) =====
SENTRY_DSN=

# --- AWS SQS (raw upload trigger) ---
SQS_QUEUE_URL=
SQS_QUEUE_ARN=


LOCAL_VIDEO_ROOT
FFMPEG_PATH